        "uuid": "msg-01",
        "sender": "human",
        "text": "What is the speed of light?",
        "created_at": "2026-04-12T14:33:00Z",
        "extra_msg_field": "this_message_level_extra_should_also_be_silently_ignored"
      },
      {
        "uuid": "msg-02",
        "sender": "assistant",
        "text": "The speed of light in a vacuum is exactly 299,792,458 meters per second.",
        "created_at": "2026-04-12T14:34:00Z"
      },
      {
        "uuid": "msg-03",
        "sender": "human",
        "text": "Why is it considered fundamental?",
        "created_at": "2026-04-12T14:35:00Z"
      },
      {
        "uuid": "msg-04",
        "sender": "assistant",
        "text": "It appears in many physical laws and relativity establishes it as the maximum speed of information.",
        "created_at": "2026-04-12T14:36:00Z"
      }
    ]
  },
  {
